# Copiá a la raíz como `.env` y duplicá DATABASE_URL en `packages/database/.env`.

# ─── DATABASE ───────────────────────────────────────────
DATABASE_URL=postgresql://ventaxlink:ventaxlink@localhost:5432/ventaxlink
# Postgres nativo Windows (ejemplo): postgresql://postgres:TU_CLAVE@localhost:5432/ventaxlink
# Migraciones: `npm run db:migrate` aplica cambios sin crear DB shadow (no hace falta CREATEDB).
# Si creás migraciones nuevas y tu usuario puede crear bases: `npm run db:migrate:dev`.

# ─── AUTH (API Nest) ───────────────────────────────────────
JWT_SECRET=change-me-min-32-characters-long!!
# Duración del token en segundos (ej. 604800 = 7 días). Solo números.
JWT_EXPIRES_IN=604800
REFRESH_TOKEN_SECRET=change-me-another-secret-key
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── NEXT (apps) ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_STORE_ORIGIN=http://localhost:3003
NEXT_PUBLIC_STORE_URL=http://localhost:3003/tienda
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
# En producción (Railway, servicio **ADMIN** Next — no el de la API): Variables del servicio admin:
# STORE_PUBLIC_BASE=https://store.ventaxlink.ar/tienda
# (alias opcional: STORE_PUBLIC_BASE_URL)
# o ADMIN_PUBLIC_URL=https://admin.ventaxlink.ar  (se deduce store.<mismo-dominio>/tienda)
# Sin eso, NEXT_PUBLIC_* suele quedar en localhost si no estaba al momento del build de Next.

# Landing marketing (web); usado en el pie de la tienda pública para el enlace "VentaXLink"
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# API NestJS (puerto por defecto 3001)
PORT=3001
# Railway / producción: comando de arranque recomendado desde la raíz del monorepo (aplica migraciones y levanta la API):
# npm run start:api:prod
# Orígenes extra para CORS (coma). En Railway: *.railway.app y https://*.ventaxlink.ar ya están permitidos en código.
# CORS_ORIGINS=https://otro-dominio.com

# ─── Hardening API / anti-bots ─────────────────────────
# Límite de tamaño para JSON y x-www-form-urlencoded
JSON_BODY_LIMIT=256kb
URLENCODED_BODY_LIMIT=256kb
# Timeout de request (ms)
REQUEST_TIMEOUT_MS=15000
KEEP_ALIVE_TIMEOUT_MS=5000
# Rate limits (por IP)
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REGISTER_WINDOW_MS=60000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_CHECKOUT_WINDOW_MS=60000
RATE_LIMIT_CHECKOUT_MAX=20
RATE_LIMIT_TRACK_WINDOW_MS=60000
RATE_LIMIT_TRACK_MAX=60
RATE_LIMIT_CONTACT_WINDOW_MS=60000
RATE_LIMIT_CONTACT_MAX=8
# POST /v1/store/:slug/mail-test (prueba SMTP, solo Pro/Mayorista)
RATE_LIMIT_MAIL_TEST_WINDOW_MS=900000
RATE_LIMIT_MAIL_TEST_MAX=5
# POST /v1/auth/forgot-password (recuperar contraseña panel comercio)
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=60000
RATE_LIMIT_FORGOT_PASSWORD_MAX=5

# Prueba de correo desde la tienda pública (plan Pro/Mayorista). Desactivá después de probar.
ENABLE_STORE_SMTP_TEST=false
# Destino del mail de prueba; si está vacío se usa el email del comercio en la base.
MAIL_TEST_TO=

# URL pública de la API: solo origen, SIN /v1 al final (si ponés …/v1, las URLs de uploads pueden romperse).
# Las imágenes subidas quedan como {PUBLIC_API_URL}/v1/uploads/… y la tienda reescribe URLs guardadas a este origen.
# En local: http://localhost:3001
PUBLIC_API_URL=http://localhost:3001

# URL base de la tienda pública (sin barra final). Se usa en los mails de pedido para el enlace de seguimiento.
# En local: http://localhost:3003
PUBLIC_STORE_URL=http://localhost:3003

# ─── Notificaciones al comercio (pedido nuevo desde la tienda) ───
# Email al email del Tenant: configurá SMTP en el servidor de la API.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true = TLS directo (puerto 465 suele ir con secure true)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Si ves "Connection timeout" a Gmail desde Railway: probá IPv4 (Node a veces se queda en IPv6).
# SMTP_IP_FAMILY=4
# Remitente (From), ej. "VentaXLink <no-reply@tudominio.com>"
MAIL_FROM=
# Opcional: defaults pensados para quedar bajo ~30s del proxy (p. ej. Railway); si no, 502 sin CORS.
# SMTP_CONNECTION_TIMEOUT_MS=12000
# SMTP_GREETING_TIMEOUT_MS=12000
# SMTP_SOCKET_TIMEOUT_MS=22000
# POST mail-test: cap del socket HTTP en la API (default 28s)
# MAIL_TEST_REQUEST_TIMEOUT_MS=28000
# Gmail (API Nest): cuenta con verificación en 2 pasos → contraseña de aplicación (no la contraseña normal).
# SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# SMTP_USER=tu@gmail.com  SMTP_PASS=xxxx xxxx xxxx xxxx  MAIL_FROM="VentaXLink <tu@gmail.com>"

# Correos internos de plataforma (coma): nuevos registros, cambios de plan, copia contacto comercial
INTERNAL_NOTIFY_EMAILS=

# Formulario de contacto/soporte (POST /v1/public/contact) — destino del mensaje
CONTACT_FORM_TO_EMAIL=
# Timeout solo para ese POST (envío SMTP puede tardar; default 45000)
CONTACT_REQUEST_TIMEOUT_MS=45000

# URL pública del panel admin (sin barra final). Enlaces en mails de plataforma y en “olvidé contraseña” (Resend).
PUBLIC_ADMIN_URL=http://localhost:3002

# ─── Resend (HTTPS): recuperación de contraseña del panel sin SMTP (ideal Railway Hobby) ───
# https://resend.com → API Key. En prueba: RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# Duración del enlace de reset (ms). Default 3600000 = 1 h.
# PASSWORD_RESET_TOKEN_TTL_MS=3600000

# Días antes de plan_expires_at para avisar renovación (Pro/Mayorista; cron diario 8:00 hora servidor)
PLAN_EXPIRY_WARNING_DAYS=7

# WhatsApp al número del comercio vía CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp/)
# Opcional: cada comercio puede guardar su clave en Configuración del panel.
CALLMEBOT_API_KEY=

# Tras `npm run db:seed`: super admin plataforma → /platform/login
#   platform@ventaxlink.local / platform123
