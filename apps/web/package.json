{
  "name": "@ventaxlink/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/next-with-clean-env.mjs dev -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && node ../../scripts/next-with-clean-env.mjs dev -p 3000",
    "build": "node ../../scripts/next-with-clean-env.mjs build",
    "start": "node ../../scripts/next-with-clean-env.mjs start",
    "lint": "node ../../scripts/next-with-clean-env.mjs lint"
  },
  "dependencies": {
    "react": "^18",
    "react-dom": "^18",
    "next": "15.5.14"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "tailwindcss": "3.4.19",
    "eslint": "^8",
    "eslint-config-next": "15.5.14"
  }
}
